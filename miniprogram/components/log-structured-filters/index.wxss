.filters {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.chips-scroll {
  width: 100%;
  white-space: nowrap;
}

.chips-row {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx;
}

.chip {
  flex-shrink: 0;
}

.clear-row {
  display: flex;
  justify-content: flex-end;
  padding: 0 32rpx;
}

.clear-text {
  color: var(--vc-color-primary);
  font-size: 24rpx;
}
