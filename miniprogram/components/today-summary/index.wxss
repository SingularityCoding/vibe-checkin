:host {
  display: block;
}

.summary {
  display: flex;
  justify-content: space-between;
}

.summary__item {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
}

.summary__item + .summary__item {
  padding-left: 24rpx;
  border-left: 1rpx solid rgba(255, 242, 232, 0.24);
}

.summary__metric {
  display: flex;
  min-width: 0;
  align-items: baseline;
  gap: 8rpx;
}

.summary__value {
  color: #fff2e8;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 68rpx;
}

.summary__unit {
  color: rgba(255, 242, 232, 0.88);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 32rpx;
}

.summary__label {
  margin-top: 8rpx;
  color: rgba(255, 242, 232, 0.72);
  font-size: 22rpx;
}

.summary__trail {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 32rpx;
}

.summary__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.summary__dot--coral {
  background: #ff9b86;
}

.summary__dot--mango {
  background: var(--vc-color-mango);
}

.summary__dot--green {
  background: var(--vc-color-green);
}

.action {
  margin-top: 48rpx;
}

.action__title {
  color: var(--vc-color-ink);
  font-size: 34rpx;
  font-weight: 600;
  line-height: 48rpx;
}

.action__description {
  margin: 12rpx 0 28rpx;
  color: var(--vc-color-text-secondary);
  font-size: 26rpx;
  line-height: 40rpx;
}

.action__title + t-button {
  margin-top: 28rpx;
}
