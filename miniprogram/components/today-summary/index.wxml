<vc-card tone="hero">
  <view class="summary">
    <view class="summary__item">
      <text class="summary__value">{{model.currentStreak}}</text>
      <text class="summary__label">当前连续</text>
    </view>
    <view class="summary__item">
      <text class="summary__value">{{model.todayMinutes}}</text>
      <text class="summary__label">今日分钟</text>
    </view>
    <view class="summary__item">
      <text class="summary__value">{{model.todayRecordCount}}</text>
      <text class="summary__label">今日记录</text>
    </view>
  </view>
  <view class="summary__trail" aria-hidden="true">
    <view class="summary__dot summary__dot--coral"></view>
    <view class="summary__dot summary__dot--mango"></view>
    <view class="summary__dot summary__dot--green"></view>
  </view>
</vc-card>

<view class="action" wx:if="{{model.actionTitle}}">
  <vc-card>
    <view class="action__title">{{model.actionTitle}}</view>
    <view class="action__description">{{model.actionDescription}}</view>
    <t-button wx:if="{{model.actionText}}" theme="primary" block="{{true}}" bind:tap="onCreateRecord">
      {{model.actionText}}
    </t-button>
  </vc-card>
</view>
