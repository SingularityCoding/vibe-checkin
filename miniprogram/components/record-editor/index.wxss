:host {
  display: block;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 36rpx;
}

.field__label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--vc-color-ink);
  font-size: 30rpx;
  font-weight: 600;
}

.field__row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.field__unit {
  color: var(--vc-color-text-secondary);
  font-size: 26rpx;
}

.field__error {
  display: block;
  margin-top: 10rpx;
  color: var(--vc-color-danger);
  font-size: 24rpx;
  line-height: 32rpx;
}
