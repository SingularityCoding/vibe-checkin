<view class="form">
  <view class="field">
    <text class="field__label">学习内容</text>
    <t-textarea
      value="{{draft.content}}"
      placeholder="这段时间学了什么？"
      maxlength="{{contentMaxLength}}"
      indicator="{{true}}"
      disabled="{{saving}}"
      bind:change="onContentChange"
    />
    <text wx:if="{{attemptedSubmit && errors.content}}" class="field__error">{{errors.content}}</text>
  </view>

  <view class="field">
    <text class="field__label">学习时长</text>
    <view class="field__row">
      <t-stepper
        value="{{draft.duration}}"
        min="{{durationMin}}"
        max="{{durationMax}}"
        step="{{durationStep}}"
        disabled="{{saving}}"
        bind:change="onDurationChange"
      />
      <text class="field__unit">分钟</text>
    </view>
    <text wx:if="{{attemptedSubmit && errors.duration}}" class="field__error">{{errors.duration}}</text>
  </view>

  <view class="field">
    <text class="field__label">学习主题</text>
    <tag-picker
      selected-tags="{{draft.tags}}"
      suggested-tags="{{suggestedTags}}"
      bind:change="onTagsChange"
    />
  </view>

  <view class="field">
    <text class="field__label">今日收获（选填）</text>
    <t-input
      value="{{draft.takeaway}}"
      placeholder="写下一个想在下次继续的想法"
      maxlength="{{takeawayMaxLength}}"
      disabled="{{saving}}"
      bind:change="onTakeawayChange"
    />
    <text wx:if="{{attemptedSubmit && errors.takeaway}}" class="field__error">{{errors.takeaway}}</text>
  </view>

  <vc-status-note wx:if="{{saveError}}" state="error" text="{{saveError}}" />
  <t-button theme="primary" block="{{true}}" loading="{{saving}}" disabled="{{saving}}" bind:tap="onSubmit">
    {{saving ? '保存中' : '保存记录'}}
  </t-button>
</view>
