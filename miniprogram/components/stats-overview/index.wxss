:host {
  display: block;
}

.loading {
  display: flex;
  min-height: 240rpx;
  align-items: center;
  justify-content: center;
}

.retry-button {
  margin-top: 20rpx;
}

.streak {
  color: #fff2e8;
  font-size: 44rpx;
  font-weight: 700;
}

.streak__secondary {
  margin-top: 16rpx;
  color: rgba(255, 242, 232, 0.72);
  font-size: 24rpx;
}

.totals {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.total {
  min-width: 0;
  flex: 1;
}
