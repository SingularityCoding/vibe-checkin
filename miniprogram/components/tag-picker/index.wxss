:host {
  display: block;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.placeholder {
  display: inline-flex;
  min-height: 64rpx;
  align-items: center;
  padding: 0 24rpx;
  border: 1rpx dashed var(--vc-color-border);
  border-radius: var(--vc-radius-sm);
  color: var(--vc-color-text-secondary);
  font-size: 26rpx;
}
