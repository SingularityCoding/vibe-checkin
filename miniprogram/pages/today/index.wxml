<view class="vc-page">
  <view class="vc-page__header">
    <view>
      <view class="vc-page__title">今天</view>
      <view class="vc-page__subtitle">{{todayLabel}}</view>
    </view>
    <view class="vc-icon-button" bindtap="openSettings" aria-label="打开设置">
      <t-icon name="setting-1" size="36rpx" />
    </view>
  </view>

  <view wx:if="{{loadState === 'loading'}}" class="page-loading">
    <t-loading theme="circular" size="48rpx" text="正在读取今天的学习" />
  </view>

  <view wx:elif="{{loadState === 'error'}}">
    <vc-status-note state="error" text="{{loadError}}" />
    <t-button variant="outline" block="{{true}}" bind:tap="retryLoad">重新加载</t-button>
  </view>

  <block wx:else>
    <today-summary model="{{summary}}" bind:create-record="openRecordEditor" />
    <today-activity
      week="{{activity.week}}"
      today-records="{{activity.todayRecords}}"
      bind:open-record="openRecordDetail"
    />
  </block>
</view>
