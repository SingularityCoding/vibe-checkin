.today-summary {
  display: flex;
  justify-content: space-between;
}

.today-summary__item {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
}

.today-summary__item + .today-summary__item {
  padding-left: 24rpx;
  border-left: 1rpx solid rgba(255, 242, 232, 0.24);
}

.today-summary__value {
  color: #fff2e8;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 68rpx;
}

.today-summary__label {
  margin-top: 8rpx;
  color: rgba(255, 242, 232, 0.72);
  font-size: 22rpx;
}

.today-summary__trail {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 32rpx;
}

.today-summary__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.today-summary__dot--coral {
  background: #ff9b86;
}

.today-summary__dot--mango {
  background: var(--vc-color-mango);
}

.today-summary__dot--green {
  background: var(--vc-color-green);
}
