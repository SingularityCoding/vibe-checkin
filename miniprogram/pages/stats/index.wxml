<view class="vc-page">
  <view class="vc-page__header">
    <view>
      <view class="vc-page__title">学习统计</view>
      <view class="vc-page__subtitle">用真实记录看见投入，而不是制造压力。</view>
    </view>
  </view>

  <vc-card>
    <vc-empty-state
      icon="chart-bar"
      title="从一次学习开始"
      description="有学习记录后，这里会展示连续学习、投入趋势和学习主题。"
      action-text="记录第一次学习"
      bind:action="openRecordEditor"
    />
  </vc-card>
</view>
