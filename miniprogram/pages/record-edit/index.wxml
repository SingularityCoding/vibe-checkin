<view class="vc-page">
  <view class="vc-page__header">
    <view>
      <view class="vc-page__title">{{mode === 'edit' ? '编辑记录' : '记录学习'}}</view>
      <view class="vc-page__subtitle">{{dateLabel}} · 学习日期不可修改</view>
    </view>
  </view>

  <record-editor
    mode="{{mode}}"
    initial-draft="{{initialDraft}}"
    suggested-tags="{{suggestedTags}}"
    saving="{{saving}}"
    save-error="{{saveError}}"
    bind:submit="submitRecord"
    bind:dirty-change="onDirtyChange"
    bind:delete-record="deleteRecord"
  />
</view>
