<view class="vc-page">
  <view class="vc-page__header">
    <view>
      <view class="vc-page__title">设置</view>
      <view class="vc-page__subtitle">管理学习偏好、同步状态与数据。</view>
    </view>
  </view>

  <vc-status-note class="load-error" wx:if="{{loadError}}" state="error" text="{{loadError}}" />

  <view class="settings-section settings-section--first">
    <settings-preference
      preference="{{preference}}"
      saving="{{savingPreference}}"
      save-error="{{preferenceError}}"
      bind:save-preference="savePreference"
    />
  </view>
  <view class="settings-section">
    <settings-sync sync-info="{{syncInfo}}" bind:reload="reloadFromCloud" />
  </view>
  <view class="settings-section">
    <settings-danger-zone
      visible="{{dangerState.visible}}"
      removing="{{dangerState.removing}}"
      remove-error="{{dangerState.removeError}}"
      bind:remove-all="removeAllRecords"
    />
  </view>
  <view class="settings-section">
    <settings-about version="{{version}}" bind:open-privacy="openPrivacy" />
  </view>
</view>
