<view class="vc-page">
  <view class="vc-page__header">
    <view>
      <view class="vc-page__title">学习日志</view>
      <view class="vc-page__subtitle">每一次学习都会成为可回看的上下文。</view>
    </view>
  </view>

  <vc-card>
    <vc-empty-state
      icon="file"
      title="还没有学习记录"
      description="完成第一次记录后，学习内容会按日期出现在这里。"
      action-text="记录第一次学习"
      bind:action="openRecordEditor"
    />
  </vc-card>
</view>
