<view class="vc-page">
  <view class="vc-page__header">
    <view>
      <view class="vc-page__title">学习日志</view>
      <view class="vc-page__subtitle">每一次学习都会成为可回看的上下文。</view>
    </view>
  </view>

  <log-structured-filters
    date-options="{{filterOptions.dates}}"
    tag-options="{{filterOptions.tags}}"
    value="{{structuredFilter}}"
    bind:change="onStructuredFilterChange"
    bind:clear="clearStructuredFilter"
  />
  <log-keyword-search
    keyword="{{keyword}}"
    result-summary="{{resultSummary}}"
    has-active-filters="{{hasActiveFilters}}"
    bind:keyword-change="onKeywordChange"
    bind:clear-all="clearAllFilters"
  />
  <log-timeline
    load-state="{{loadState}}"
    summary="{{timeline.summary}}"
    groups="{{timeline.groups}}"
    has-active-filters="{{hasActiveFilters}}"
    bind:retry="retryLoad"
    bind:create-record="openRecordEditor"
    bind:open-record="openRecordDetail"
  />
</view>
