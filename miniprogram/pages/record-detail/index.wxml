<view class="vc-page">
  <view class="vc-page__header">
    <view>
      <view class="vc-page__title">学习详情</view>
      <view class="vc-page__subtitle">完整回看这一段学习。</view>
    </view>
  </view>

  <record-detail
    load-state="{{loadState}}"
    model="{{model}}"
    error-message="{{errorMessage}}"
    bind:retry="retryLoad"
    bind:edit-record="openEditRecord"
    bind:return-to-log="returnToLog"
  />
</view>
